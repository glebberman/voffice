includes:
    - vendor/larastan/larastan/extension.neon

parameters:
    # Максимальный уровень, без baseline и без ignoreErrors: всё, что находил
    # анализатор, поправлено типами и кодом.
    #
    # Что для этого понадобилось — в docs/reference/komandy-okruzhenie.md.
    level: 10

    paths:
        - app
        - database
        - routes
        - tests

    # Анализ упирается в дефолтные 128M
    parallel:
        maximumNumberOfProcesses: 4
