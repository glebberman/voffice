includes:
    - vendor/larastan/larastan/extension.neon

parameters:
    # Уровень 7 держится без baseline и без ignoreErrors — всё, что находил
    # анализатор, поправлено типами и кодом.
    #
    # На 8 остаётся 41 ошибка одного рода: $request->user() по сигнатуре
    # nullable, timestamps тоже. За middleware auth они не бывают null, поэтому
    # «починка» свелась бы к веткам, которые никогда не выполнятся, либо к
    # утверждениям типов — то есть к заглушкам.
    level: 7

    paths:
        - app
        - database
        - routes
        - tests

    # Анализ упирается в дефолтные 128M
    parallel:
        maximumNumberOfProcesses: 4
